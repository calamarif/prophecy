      "properties" : {
        "ports" : null,
        "scriptMethodHeader" : "def Script(spark: SparkSession, in0: DataFrame) -> DataFrame:",
        "scriptMethodFooter" : "return out0",
        "script" : "\nimport cx_Oracle\ndsn = dbutils.secrets.get(scope = {{execute_data_refresh_event}}, key = \"dsn\")\nusername = dbutils.secrets.get(scope = {{execute_data_refresh_event}}, key = \"username\")\npassword = dbutils.secrets.get(scope = {{execute_data_refresh_event}}, key = \"password\")\n\nresult = []\nfor row in in0.collect():\n  with cx_Oracle.connect(cfg.username, cfg.password, cfg.dsn) as connection:\n    with connection.cursor() as cursor:\n      ctl_batch_id = cursor.var(str)\n      maximum_degree_of_parallelism = cursor.var(str)\n      target_schema_list = cursor.var(str)\n      retry_failed_steps = cursor.var(str)\n      RETURN_VALUE = cursor.var(str)\n      cursor.callproc('ctl.execute_data_refresh_event', [row['ctl_batch_id'],row['maximum_degree_of_parallelism'],row['target_schema_list'],row['retry_failed_steps'],ctl_batch_id,maximum_degree_of_parallelism,target_schema_list,retry_failed_steps,RETURN_VALUE])\n      result += [Row(ctl_batch_id = row['ctl_batch_id'],maximum_degree_of_parallelism = row['maximum_degree_of_parallelism'],target_schema_list = row['target_schema_list'],retry_failed_steps = row['retry_failed_steps'],RETURN_VALUE = RETURN_VALUE)]\nout = spark.createDataFrame(result, \nStructType([\nStructField(\"ctl_batch_id\", IntegerType(), True),\nStructField(\"maximum_degree_of_parallelism\", IntegerType(), True),\nStructField(\"target_schema_list\", StringType(), True),\nStructField(\"retry_failed_steps\", StringType(), True),\nStructField(\"RETURN_VALUE\", IntegerType(), True)\n])\n)\n"
      },
