      "properties" : {
        "scriptMethodHeader" : "def Script(spark: SparkSession, in: DataFrame) -> DataFrame:",
        "scriptMethodFooter" : "return out",
        "script" : "\nimport cx_Oracle\ndsn = dbutils.secrets.get(scope = {{Sp_Insert_S_Premium_Tran}}, key = \"dsn\")\nusername = dbutils.secrets.get(scope = {{Sp_Insert_S_Premium_Tran}}, key = \"username\")\npassword = dbutils.secrets.get(scope = {{Sp_Insert_S_Premium_Tran}}, key = \"password\")\n\nresult = []\nfor row in in0.collect():\n  with cx_Oracle.connect(cfg.username, cfg.password, cfg.dsn) as connection:\n    with connection.cursor() as cursor:\n      Months_Prior_Count = cursor.var(str)\n      CTL_BATCH_ID = cursor.var(str)\n      CTL_JOB_ID = cursor.var(str)\n      CTL_LOAD_DM = cursor.var(str)\n      RETURN_VALUE = cursor.var(str)\n      cursor.callproc('BDV.INSERT_S_PREMIUM_TRAN_NET', [row['Months_Prior_Count'],row['CTL_BATCH_ID'],row['CTL_JOB_ID'],row['CTL_LOAD_DM'],Months_Prior_Count,CTL_BATCH_ID,CTL_JOB_ID,CTL_LOAD_DM,RETURN_VALUE])\n      result += [Row(Months_Prior_Count = row['Months_Prior_Count'],CTL_BATCH_ID = row['CTL_BATCH_ID'],CTL_JOB_ID = row['CTL_JOB_ID'],CTL_LOAD_DM = row['CTL_LOAD_DM'],RETURN_VALUE = RETURN_VALUE)]\nout = spark.createDataFrame(result, \nStructType([\nStructField(\"Months_Prior_Count\", IntegerType(), True),\nStructField(\"CTL_BATCH_ID\", IntegerType(), True),\nStructField(\"CTL_JOB_ID\", IntegerType(), True),\nStructField(\"CTL_LOAD_DM\", TimestampType(), True),\nStructField(\"RETURN_VALUE\", IntegerType(), True)\n])\n)\n"
      },
