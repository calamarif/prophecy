        "scriptMethodHeader" : "def Script(spark: SparkSession, in0: DataFrame) -> DataFrame:",
        "scriptMethodFooter" : "return out0",
        "script" : "\nimport cx_Oracle\ndsn = dbutils.secrets.get(scope = {{execute_data_refresh_event_wait}}, key = \"dsn\")\nusername = dbutils.secrets.get(scope = {{execute_data_refresh_event_wait}}, key = \"username\")\npassword = dbutils.secrets.get(scope = {{execute_data_refresh_event_wait}}, key = \"password\")\n\nresult = []\nfor row in in0.collect():\n  with cx_Oracle.connect(cfg.username, cfg.password, cfg.dsn) as connection:\n    with connection.cursor() as cursor:\n      ctl_batch_id = cursor.var(str)\n      RETURN_VALUE = cursor.var(str)\n      cursor.callproc('ctl.execute_data_refresh_event_wait', [row['ctl_batch_id'],ctl_batch_id,RETURN_VALUE])\n      result += [Row(ctl_batch_id = row['ctl_batch_id'],RETURN_VALUE = RETURN_VALUE)]\nout = spark.createDataFrame(result, \nStructType([\nStructField(\"ctl_batch_id\", IntegerType(), True),\nStructField(\"RETURN_VALUE\", IntegerType(), True)\n])\n)\n"
      },
