        "x" : 820,
        "y" : 120,
        "phase" : 0
      },
      "properties" : {
        "columnsSelector" : [ "MWueKOVf##contract", "MWueKOVf##payment_method", "MWueKOVf##internet_type" ],
        "expressions" : [ {
          "expression" : {
            "expression" : "*"
          },
          "_row_id" : "1863022100"
        }, {
          "expression" : {
            "expression" : "-- Contract type encoding (higher = longer commitment)\nCASE\n  WHEN UPPER(contract) LIKE '%MONTH-TO-MONTH%'\n    THEN 0\n  WHEN UPPER(contract) LIKE '%ONE YEAR%'\n    THEN 1\n  WHEN UPPER(contract) LIKE '%TWO YEAR%'\n    THEN 2\n  ELSE 0\nEND"
          },
          "alias" : "contract_type_encoded",
          "_row_id" : "1202018237"
        }, {
          "expression" : {
            "expression" : "-- Payment method encoding\nCASE\n  WHEN UPPER(payment_method) LIKE '%BANK%'\n    THEN 1\n  WHEN UPPER(payment_method) LIKE '%CREDIT%'\n    THEN 2\n  WHEN UPPER(payment_method) LIKE '%MAILED%'\n    THEN 0\n  ELSE 0\nEND"
          },
          "alias" : "payment_method_encoded",
          "_row_id" : "1441057036"
        }, {
          "expression" : {
            "expression" : "-- Internet type encoding\nCASE\n  WHEN internet_type IS NULL OR UPPER(internet_type) = 'NONE' OR UPPER(internet_type) = 'UNKNOWN'\n    THEN 0\n  WHEN UPPER(internet_type) LIKE '%DSL%'\n    THEN 1\n  WHEN UPPER(internet_type) LIKE '%FIBER%'\n    THEN 2\n  WHEN UPPER(internet_type) LIKE '%CABLE%'\n    THEN 3\n  ELSE 0\nEND"
          },
          "alias" : "internet_type_encoded",
          "_row_id" : "1823488081"
        } ]
      },
